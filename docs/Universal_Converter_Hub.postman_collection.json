{
  "info": {
    "name": "Universal Converter Hub API",
    "description": "Complete API collection for Universal Converter Hub. Includes authentication, CRUD operations, search, favorites, history, analytics, and currency conversion.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data) {",
                  "  pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data) {",
                  "  pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@converterhub.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data) {",
                  "  pm.collectionVariables.set('adminToken', jsonData.data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh-token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data) {",
                  "  pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            },
            "url": "{{baseUrl}}/auth/forgot-password"
          }
        }
      ]
    },
    {
      "name": "📁 Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Get Category by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories/length"
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pressure\",\n  \"slug\": \"pressure\",\n  \"icon\": \"🌡️\",\n  \"description\": \"Convert between pressure units\",\n  \"displayOrder\": 25\n}"
            },
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pressure Updated\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "🔄 Converters",
      "item": [
        {
          "name": "Get All Converters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/converters?page=0&size=20&sort=name,asc",
              "host": ["{{baseUrl}}"],
              "path": ["converters"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "name,asc" }
              ]
            }
          }
        },
        {
          "name": "Get Converter by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/converters/kg-to-g"
          }
        },
        {
          "name": "Get Converters by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/converters/category/length?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["converters", "category", "length"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Popular Converters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/converters/popular?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["converters", "popular"],
              "query": [
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Trending Converters",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/converters/trending"
          }
        },
        {
          "name": "Track Conversion",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/converters/kg-to-g/track"
          }
        },
        {
          "name": "Create Converter (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pascal to Bar\",\n  \"slug\": \"pascal-to-bar\",\n  \"fromUnit\": \"Pascal\",\n  \"toUnit\": \"Bar\",\n  \"formula\": \"value / 100000\",\n  \"categorySlug\": \"pressure\",\n  \"seoTitle\": \"Pascal to Bar Converter\",\n  \"seoDescription\": \"Convert Pascal to Bar instantly\"\n}"
            },
            "url": "{{baseUrl}}/converters"
          }
        },
        {
          "name": "Update Converter (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Converter\",\n  \"seoTitle\": \"Updated SEO Title\"\n}"
            },
            "url": "{{baseUrl}}/converters/{{converterId}}"
          }
        },
        {
          "name": "Delete Converter (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/converters/{{converterId}}"
          }
        }
      ]
    },
    {
      "name": "🔍 Search",
      "item": [
        {
          "name": "Search Converters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/search?q=temperature&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["search"],
              "query": [
                { "key": "q", "value": "temperature" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "⭐ Favorites",
      "item": [
        {
          "name": "Get My Favorites",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/favorites?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["favorites"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Add Favorite",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"converterSlug\": \"kg-to-g\"\n}"
            },
            "url": "{{baseUrl}}/favorites"
          }
        },
        {
          "name": "Check If Favorite",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/favorites/check/kg-to-g"
          }
        },
        {
          "name": "Remove Favorite",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/favorites/kg-to-g"
          }
        }
      ]
    },
    {
      "name": "📜 History",
      "item": [
        {
          "name": "Get My History",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/history?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["history"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Save History Entry",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"converterSlug\": \"kg-to-g\",\n  \"inputValue\": \"5\",\n  \"outputValue\": \"5000\",\n  \"fromUnit\": \"Kilogram\",\n  \"toUnit\": \"Gram\"\n}"
            },
            "url": "{{baseUrl}}/history"
          }
        },
        {
          "name": "Delete History Entry",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/history/{{historyId}}"
          }
        },
        {
          "name": "Clear All History",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/history/clear"
          }
        }
      ]
    },
    {
      "name": "💱 Currency",
      "item": [
        {
          "name": "Get Exchange Rates",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/currency/rates/USD"
          }
        },
        {
          "name": "Convert Currency",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/currency/convert?from=USD&to=EUR&amount=100",
              "host": ["{{baseUrl}}"],
              "path": ["currency", "convert"],
              "query": [
                { "key": "from", "value": "USD" },
                { "key": "to", "value": "EUR" },
                { "key": "amount", "value": "100" }
              ]
            }
          }
        },
        {
          "name": "Get Supported Currencies",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/currency/currencies"
          }
        }
      ]
    },
    {
      "name": "📊 Analytics",
      "item": [
        {
          "name": "Track Page Visit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"converterSlug\": \"kg-to-g\",\n  \"eventType\": \"PAGE_VISIT\"\n}"
            },
            "url": "{{baseUrl}}/analytics/track"
          }
        },
        {
          "name": "Get Popular Converters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/analytics/popular?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "popular"],
              "query": [
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Dashboard Analytics (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/analytics/dashboard"
          }
        }
      ]
    },
    {
      "name": "👤 User Profile",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/user/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John Updated\",\n  \"lastName\": \"Doe Updated\"\n}"
            },
            "url": "{{baseUrl}}/user/profile"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Password@123\",\n  \"newPassword\": \"NewPassword@456\"\n}"
            },
            "url": "{{baseUrl}}/user/change-password"
          }
        }
      ]
    },
    {
      "name": "🛡️ Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Toggle User Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/users/{{userId}}/toggle-status"
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/users/{{userId}}"
          }
        },
        {
          "name": "Get Admin Analytics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/analytics"
          }
        }
      ]
    }
  ]
}
