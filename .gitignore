# ═══════════════════════════════════════════════════════════════
# Universal Converter Hub — .gitignore
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# Environment & Secrets
# ─────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─────────────────────────────────────────────
# Java / Maven / Spring Boot
# ─────────────────────────────────────────────
backend/target/
backend/.mvn/
backend/mvnw
backend/mvnw.cmd
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*

# ─────────────────────────────────────────────
# Node / React / Vite
# ─────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.cache/
frontend/.vite/
*.tsbuildinfo

# ─────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────
docker-compose.override.yml

# ─────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────
*.bak
*.tmp
*.temp
coverage/
.nyc_output/
