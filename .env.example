# ═══════════════════════════════════════════════════════════════
# Universal Converter Hub — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_DB=converterhub
POSTGRES_USER=converterhub
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_PORT=5432

# For Neon PostgreSQL (production):
# DATABASE_URL=jdbc:postgresql://ep-xxxx.us-east-1.aws.neon.tech/converterhub?sslmode=require
# DATABASE_USERNAME=your_neon_user
# DATABASE_PASSWORD=your_neon_password

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password (if using managed Redis)
# REDIS_URL=redis://default:password@host:port (for managed Redis)

# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────
# MUST be at least 256 bits (32+ characters) for HS256
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-64-characters-for-production
JWT_ACCESS_EXPIRATION=900000        # 15 minutes in ms
JWT_REFRESH_EXPIRATION=604800000    # 7 days in ms

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────
# External APIs
# ─────────────────────────────────────────────
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest

# ─────────────────────────────────────────────
# Spring Boot
# ─────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
FRONTEND_PORT=3000
BACKEND_PORT=8080
